{
  "name": "nhs-complaint-local-site",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "vite --config vite.config.mjs",
    "build": "vite build --config vite.config.mjs",
    "preview": "vite preview --config vite.config.mjs",
    "data:update:wards": "node ./scripts/update-wards-gm.mjs",
    "data:update:councils": "node ./scripts/update-councils-gm.mjs",
    "data:update:election:current": "node ./scripts/update-ward-election-current-gm.mjs",
    "data:update:election:current:force-all": "FORCE_REFRESH_ALL_CURRENT=1 node ./scripts/update-ward-election-current-gm.mjs",
    "data:update:election:history": "node ./scripts/update-ward-election-history-gm.mjs",
    "data:update:election:history:force": "FORCE_REBUILD_HISTORY=1 node ./scripts/update-ward-election-history-gm.mjs",
    "data:update:deprivation:source": "node ./scripts/update-deprivation-source.mjs",
    "data:update:census:source": "node ./scripts/update-census-source.mjs",
    "data:derive:deprivation": "node ./scripts/run-deprivation-derivatives.mjs",
    "data:derive:census": "node ./scripts/run-census-derivatives.mjs",
    "data:update:gp": "node ./scripts/run-gp-import.mjs",
    "updates:maintenance": "node ./scripts/updates-maintenance.mjs",
    "updates:maintenance:refresh-all-current": "FORCE_REFRESH_ALL_CURRENT=1 node ./scripts/updates-maintenance.mjs",
    "updates:maintenance:rebuild-history": "FORCE_REBUILD_HISTORY=1 node ./scripts/updates-maintenance.mjs",
    "deprivation:index:update": "node ./scripts/build-ward-deprivation-vote-index.mjs",
    "deprivation:groups:update": "node ./scripts/build-ward-deprivation-groups.mjs",
    "census:update": "python3 ./census/build_england_census_lsoa_summary.py && node ./scripts/build-ward-census-demographics.mjs",
    "gp:import": "node ./scripts/import-gp-ratings-from-nhs.mjs",
    "winners:update:manual": "node ./scripts/update-ward-winners-manual.mjs"
  },
  "devDependencies": {
    "flag-icons": "^7.3.2",
    "playwright": "^1.54.2",
    "vite": "latest"
  },
  "dependencies": {
    "@turf/turf": "^7.3.5"
  }
}
